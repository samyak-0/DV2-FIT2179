{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Sea Surface Temperature Anomalies (1998-2017)",
    "fontSize": 16,
    "font": "Playfair Display",
    "anchor": "start",
    "color": "#0a1628"
  },
  "width": "container",
  "height": 350,
  "data": {
    "url": "coral_bleaching_multifactor_dataset.csv"
  },
  "transform": [
    {
      "aggregate": [{"op": "mean", "field": "SSTA", "as": "Average_SSTA"}],
      "groupby": ["Year"]
    }
  ],
  "mark": {
    "type": "line",
    "color": "#e07b39",
    "strokeWidth": 3,
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "quantitative",
      "axis": {
        "format": "d",
        "title": "Year",
        "grid": false,
        "labelFlush": true
      }
    },
    "y": {
      "field": "Average_SSTA",
      "type": "quantitative",
      "axis": {
        "title": "Mean Temperature Anomaly (°C)",
        "grid": true
      }
    },
    "tooltip": [
      {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
      {"field": "Average_SSTA", "type": "quantitative", "title": "Avg Anomaly (°C)", "format": ".2f"}
    ]
  },
  "config": {
    "background": "transparent",
    "axis": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}