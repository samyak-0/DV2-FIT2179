{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "manta-tow-by-reef.csv"
  },
  "transform": [
    {
      "filter": "datum.REPORT_YEAR == choose_year"
    },
    {
      "filter": "!test(/[0-9]/, datum.REEF_NAME)"
    },
    {
      "calculate": "datum.REEF_NAME + ' (' + datum.SECTOR + ')'",
      "as": "Unique_Reef_Label"
    }
  ],
  "vconcat": [
    {
      "title": {
        "text": "Predator Density vs. Hard Coral Baselines",
        "font": "Playfair Display",
        "fontSize": 15,
        "anchor": "start"
      },
      "width": "container",
      "height": 220,
      "params": [
        {
          "name": "choose_year",
          "value": 2015,
          "select": {"type": "point", "fields": ["REPORT_YEAR"]},
          "bind": {
            "input": "select",
            "options": [1995, 2000, 2005, 2010, 2015, 2020, 2023],
            "name": "Select Survey Year: "
          }
        },
        {
          "name": "brush",
          "select": {"type": "interval", "encodings": ["x", "y"]}
        }
      ],
      "mark": {"type": "circle", "size": 65, "opacity": 0.7},
      "encoding": {
        "x": {
          "field": "MEAN_COTS_PER_TOW",
          "type": "quantitative",
          "scale": {"type": "symlog", "constant": 0.1},
          "axis": {"title": "Starfish Count (Symlog Scale)", "grid": true}
        },
        "y": {
          "field": "MEAN_LIVE_CORAL",
          "type": "quantitative",
          "scale": {"domain": [0, 80]},
          "axis": {"title": "Live Coral Cover %"}
        },
        "color": {
          "condition": {
            "param": "brush",
            "field": "SECTOR",
            "type": "nominal",
            "scale": {"scheme": "tableau10"}
          },
          "value": "rgba(10, 22, 40, 0.12)"
        },
        "tooltip": [
          {"field": "REEF_NAME", "type": "nominal", "title": "Reef"},
          {"field": "SECTOR", "type": "nominal", "title": "Sector"},
          {"field": "MEAN_LIVE_CORAL", "type": "quantitative", "title": "Coral %", "format": ".1f"},
          {"field": "MEAN_COTS_PER_TOW", "type": "quantitative", "title": "COTS per Tow", "format": ".2f"}
        ]
      }
    },
    {
      "title": {
        "text": "Selected Reef Damage Tracking",
        "font": "Playfair Display",
        "fontSize": 13,
        "anchor": "start"
      },
      "width": "container",
      "height": 160,
      "transform": [
        {"filter": {"param": "brush"}},
        {
          "window": [{"op": "rank", "as": "rank"}],
          "sort": [{"field": "MEAN_LIVE_CORAL", "order": "descending"}]
        },
        {"filter": "datum.rank <= 10"}
      ],
      "mark": {"type": "bar", "color": "#e07b39", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {
          "field": "MEAN_LIVE_CORAL",
          "type": "quantitative",
          "axis": {"title": "Live Coral Cover %"}
        },
        "y": {
          "field": "Unique_Reef_Label",
          "type": "nominal",
          "axis": {"title": null},
          "sort": "-x"
        },
        "tooltip": [
          {"field": "REEF_NAME", "type": "nominal", "title": "Reef Name"},
          {"field": "SECTOR", "type": "nominal", "title": "Sector Location"},
          {"field": "MEAN_LIVE_CORAL", "type": "quantitative", "title": "Coral Cover %", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "axis": {"labelFont": "DM Sans", "titleFont": "DM Sans"}
  }
}